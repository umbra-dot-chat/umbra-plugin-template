{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "declaration": false,
    "baseUrl": ".",
    "paths": {
      "@umbra/plugin-sdk": ["../umbra-plugin-sdk/src/index"]
    }
  },
  "include": ["src/**/*"]
}
